# Copy this file to .env.local and adjust if needed.
# .env.local is gitignored.
#
# Overlay on top of .env, loaded ONLY by local-dev Make targets:
# `make dev`, `make backend`, `make worker`, `make frontend`,
# `make infra-up`, `make app-up`, `make test`, `make check`.
#
# AWS deploy targets (`make deploy`, `make frontend-deploy`,
# `make teardown`) ignore this file.

# --- AWS / Moto ------------------------------------------------------------
# Point the AWS SDK at the local Moto Server brought up by `make infra-up`.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Fixed resource names used by the dev compose stack (see compose.yaml).
IMAGES_BUCKET=aws-image-processing-demo-images-local
IMAGES_TABLE=aws-image-processing-demo-images-local

# --- Nuxt dev --------------------------------------------------------------
# Frontend (:3000) and backend (:8000) are separate processes in host mode,
# so the Nuxt bundle needs an absolute API base. The prod bundle uses ''
# (same-origin via CloudFront); the Docker stack injects this in compose.yaml.
NUXT_PUBLIC_API_BASE=http://localhost:8000

# --- Temporal dev server ---------------------------------------------------
# Override Temporal Cloud with the local dev server brought up by
# `make infra-up`. Empty TLS material disables mTLS.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=
