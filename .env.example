# Copy this file to .env and fill in the values.
# .env is gitignored.

# --- Temporal --------------------------------------------------------------
# Default: the local dev server brought up by `make infra-up`.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# For Temporal Cloud, point to your namespace endpoint and provide an
# mTLS client cert/key pair (paths relative to the repo root):
#TEMPORAL_ADDRESS=<namespace>.<account>.tmprl.cloud:7233
#TEMPORAL_NAMESPACE=<namespace>.<account>
#TEMPORAL_TLS_CERT=ca.pem
#TEMPORAL_TLS_KEY=ca.key

TEMPORAL_TASK_QUEUE=image-processing

# --- AWS / Moto ------------------------------------------------------------
# Local Moto endpoint. Leave AWS_ENDPOINT_URL unset to hit real AWS.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Fixed names for local dev; in AWS both resource names are
# generated by OpenTofu (prefix `aws-image-processing-demo-`)
# and injected into the worker/api environment by Tofu.
IMAGES_BUCKET=aws-image-processing-demo-images-local
IMAGES_TABLE=aws-image-processing-demo-images-local

# --- Anthropic -------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Cloudflare (only needed for `tofu apply`) -----------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
