# Copy this file to .env and fill in the values.
# .env is gitignored.

# --- Temporal --------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS_CERT=
TEMPORAL_TLS_KEY=
TEMPORAL_TASK_QUEUE=image-processing

# --- AWS / LocalStack ------------------------------------------------------
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Fixed names for LocalStack; in AWS both resource names are
# generated by OpenTofu (prefix `temporal-aws-autoscaling-demo-`)
# and injected into the worker/api environment by Tofu.
IMAGES_BUCKET=temporal-aws-autoscaling-demo-images-local
IMAGES_TABLE=temporal-aws-autoscaling-demo-images-local

# --- Anthropic -------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Cloudflare (only needed for `tofu apply`) -----------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
