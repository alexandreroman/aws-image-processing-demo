# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.
#
# This is the canonical environment for the project. `make deploy`,
# `make frontend-deploy`, and `make teardown` load it (only). For local
# development against Moto + a Temporal dev server, also create a
# .env.local that overlays the dev-only knobs — see .env.local.example.
#
# AWS authentication is NOT in this file — it comes from your AWS CLI
# profile / SSO session. Run `aws sts get-caller-identity` to confirm
# you are pointing at the right account before deploying.

# --- Temporal Cloud --------------------------------------------------------
TEMPORAL_ADDRESS=<namespace>.<account>.tmprl.cloud:7233
TEMPORAL_NAMESPACE=<namespace>.<account>

# Paths to the Temporal Cloud mTLS client material (PEM-encoded).
# Relative paths are resolved from the repo root. The deploy scripts read
# the file contents and inject them as TF_VAR_temporal_tls_cert_pem /
# TF_VAR_temporal_tls_key_pem so the values flow into Secrets Manager.
TEMPORAL_TLS_CERT=path/to/client.pem
TEMPORAL_TLS_KEY=path/to/client.key

# Legacy single-queue setting used in local dev (`make dev`, `make app-up`).
# Deploy targets don't consult this — Tofu sets WORKER_TASK_QUEUE_ECS and
# WORKER_TASK_QUEUE_LAMBDA on the deployed backend Lambda so the runtime
# selector appears in the UI. Those two vars are NOT user-tunable here.
TEMPORAL_TASK_QUEUE=image-processing

# --- Temporal Cloud assume-role flow (Lambda runtime only) -----------------
# External ID Temporal Cloud presents when assuming the invoker role. Any
# string matching `[A-Za-z0-9=,.@:/-]{2,1224}` works. The fixed value below
# is fine for this demo (single-tenant, your AWS account is the only trust
# principal). For production / multi-tenant, generate a random secret per
# deployment (e.g. `openssl rand -hex 32`).
#
# The 5 Temporal Cloud invoker AWS account IDs are baked into the Tofu
# default for `temporal_cloud_aws_account_ids` — no user config needed.
TEMPORAL_CLOUD_EXTERNAL_ID=aws-image-processing-demo

# --- Temporal Cloud metrics ------------------------------------------------
# Service-account API key with the Metrics Read-Only role. Used by the ADOT
# collector to scrape metrics.temporal.io and drive ECS worker autoscaling.
# Create one under Settings → Service Accounts in the Temporal Cloud UI.
TEMPORAL_METRICS_API_KEY=

# --- Anthropic -------------------------------------------------------------
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- AWS deploy region -----------------------------------------------------
AWS_REGION=eu-west-1

# Optional: AWS CLI profile (SSO profile name). When set, scripts/lib/env.sh
# exports it so the AWS SDK picks up the right account. Leave unset to rely
# on your shell's default credentials chain.
# Example: AWS_PROFILE=SolutionsArchitecture/AWSAdministratorAccess
#AWS_PROFILE=

# --- Worker image (optional) -----------------------------------------------
# Defaults to the image built by the GHCR workflow on main.
#WORKER_IMAGE=ghcr.io/alexandreroman/aws-image-processing-demo:latest

# --- Custom domain via Cloudflare (optional) -------------------------------
# When DOMAIN_NAME is empty, the demo is served on the default
# *.cloudfront.net hostname and Cloudflare credentials are not required.
#DOMAIN_NAME=example.com
#SUBDOMAIN=demo
#CLOUDFLARE_API_TOKEN=
#CLOUDFLARE_ZONE_ID=
