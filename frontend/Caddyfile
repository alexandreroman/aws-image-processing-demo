# Single-origin front door for the compose stack. Mirrors the prod
# CloudFront topology: /api/* → backend, /* → SSG bundle with SPA fallback.
:3000 {
    handle_path /images/* {
        # Mirror of the prod CloudFront /images/* behavior: strip the prefix,
        # prepend the fixed dev bucket name, and forward to Moto.
        rewrite * /aws-image-processing-demo-images-local{uri}
        reverse_proxy moto:5000
    }
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle {
        root * /srv
        # 200.html is Nuxt's lightweight SPA fallback (no prerendered
        # route baked in). Serving index.html instead would hydrate the
        # home page on /pipelines/{id} refreshes.
        try_files {path} /200.html
        file_server
    }
}
